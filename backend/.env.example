PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
DB_PATH=./okte.db
CORS_ORIGIN=http://localhost:5173

# Public URL of the frontend (used for links in emails, e.g. password reset / email verification)
APP_URL=http://localhost:5173

# Email — Resend (https://resend.com). When SMTP_HOST is set, emails are sent
# via SMTP instead of logged to the console.
#
# Quick start:
#   1. Sign up at resend.com and grab an API key from the dashboard.
#   2. Put the API key in SMTP_PASS below (it doubles as the SMTP password).
#   3. SMTP_FROM must be an address on a domain verified in Resend.
#      This project uses pulkra.com (already verified). Example: noreply@pulkra.com
#
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM=noreply@pulkra.com

# Set to "production" to enforce JWT_SECRET requirement
# NODE_ENV=development
