PORT=3201
JWT_SECRET=change-this-to-a-long-random-string-in-production
DB_PATH=./okte.db
# Optional in dev — localhost origins are allowed automatically. Set for production.
# CORS_ORIGIN=https://onekeytoeverywhere.com

# Public URL of the frontend (used for links in emails, e.g. password reset / email verification)
APP_URL=http://localhost:5173

# Email — Resend (https://resend.com).
# Production uses Resend's HTTPS API (Railway blocks outbound SMTP on Hobby/Free).
# SMTP_* below still work for local/dev; SMTP_PASS is the Resend API key.
#
# Quick start:
#   1. Sign up at resend.com with anna@onekeytoeverywhere.com
#   2. Verify the onekeytoeverywhere.com domain in Resend
#   3. Create an API key and put it in SMTP_PASS (or RESEND_API_KEY)
#   4. SMTP_FROM must be an address on the verified domain
#
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM=One Key to Everywhere <anna@onekeytoeverywhere.com>
# Optional alias for the same Resend key:
# RESEND_API_KEY=your_resend_api_key_here

# Cloudinary — property photo uploads (https://cloudinary.com)
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Set to "production" to enforce JWT_SECRET requirement
# NODE_ENV=development
