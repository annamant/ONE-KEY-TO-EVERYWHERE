PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
DB_PATH=./okte.db
CORS_ORIGIN=http://localhost:5173

# Public URL of the frontend (used for links in emails, e.g. password reset)
APP_URL=http://localhost:5173

# Optional — when SMTP_HOST is set, emails are sent via SMTP instead of logged to console
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@onekeytoeverywhere.com

# Set to "production" to enforce JWT_SECRET requirement
# NODE_ENV=development
